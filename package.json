{
  "name": "@spectra/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for integrating with Spectra Contracts on Stellar Soroban.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "clean": "rimraf dist"
  },
  "keywords": [
    "stellar",
    "soroban",
    "sdk",
    "vault",
    "asset-basket",
    "spectra"
  ],
  "author": "Spectra Team",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^12.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
